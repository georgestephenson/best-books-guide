# Copy to .env for local overrides. Every key mirrors the TypeBox schema in
# apps/api/src/config.ts; all have dev-friendly defaults, so .env is optional when
# you run the stores via `docker compose up` (docs/07 §Local env).
#
# Production does NOT use this file — Ansible renders the real .env from Vault
# (infra/ansible/roles/app/templates/env.j2).

NODE_ENV=development
# HOST=127.0.0.1
# PORT=3000
# LOG_LEVEL=info

# Points at the docker-compose Postgres/Redis. The integration tests use their own
# database (bestbooks_test) and Redis db index — see apps/api/test/env.ts.
DATABASE_URL=postgresql://bestbooks:bestbooks@127.0.0.1:5432/bestbooks
REDIS_URL=redis://127.0.0.1:6379
