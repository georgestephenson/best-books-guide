{{ ansible_managed | comment }}
# Ansible owns this file: it's config, rendered from group_vars + Vault.
# APP_VERSION deliberately lives in .env.release, which the deploy playbook owns —
# see the note in roles/app/tasks/main.yml.
#
# Every key here has a matching entry in the TypeBox schema at
# apps/api/src/config.ts. The two move together: an unknown key is ignored, but a
# missing one fails the boot loudly (docs/02 §Cross-cutting concerns).

NODE_ENV=production
HOST=127.0.0.1
PORT={{ app_port }}
LOG_LEVEL={{ app_log_level }}

PUBLIC_BASE_URL=https://{{ domain_name }}

DATABASE_URL={{ database_url }}
REDIS_URL=redis://127.0.0.1:{{ redis_port }}

JWT_SECRET={{ vault_jwt_secret }}
{% if vault_jwt_secret_previous | default('') %}
# Rotation window: the API verifies against both and signs with JWT_SECRET.
# Drop this key on the next deploy to complete the rotation (docs/07 §Runbooks).
JWT_SECRET_PREVIOUS={{ vault_jwt_secret_previous }}
{% endif %}

AWS_REGION={{ aws_region }}
EMAIL_TRANSPORT=ses
EMAIL_FROM={{ app_email_from }}
