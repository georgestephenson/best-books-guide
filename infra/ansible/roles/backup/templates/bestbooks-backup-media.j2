#!/bin/bash
{{ ansible_managed | comment }}
# Mirror the cover-image directory to its S3 replica. `sync` is incremental, so
# this stays cheap once the catalogue settles (docs/06 §S3 buckets).
set -Eeuo pipefail

aws s3 sync "{{ app_dir }}/media" "s3://{{ media_bucket }}/" \
  --region {{ aws_region }} \
  --no-progress \
  --delete

echo "media sync ok"
{% if backup_heartbeat_url %}
curl -fsS -m 10 --retry 3 "{{ backup_heartbeat_url }}" >/dev/null
{% endif %}
