## Managed by Ansible (roles/monit)

check process bestbooks-api matching "apps/api/dist/main.js"
  start program = "/usr/bin/systemctl start bestbooks-api" with timeout 30 seconds
  stop program  = "/usr/bin/systemctl stop bestbooks-api"
  if failed host 127.0.0.1 port {{ app_port }} protocol http
    request "/healthz" with timeout 5 seconds for 2 cycles
    then restart
  if 3 restarts within 5 cycles then alert

check process nginx with pidfile /run/nginx.pid
  start program = "/usr/bin/systemctl start nginx"
  stop program  = "/usr/bin/systemctl stop nginx"
  if failed host 127.0.0.1 port 80 protocol http for 2 cycles then restart

check system {{ inventory_hostname }}
  if memory usage > 85% for 3 cycles then alert
  if loadavg (5min) > {{ monit_load_threshold }} for 3 cycles then alert

check filesystem rootfs with path /
  if space usage > 80% then alert
  if space usage > 90% then alert

# External reachability + TLS validity of the public endpoint.
check host bestbooks-public with address {{ domain_name }}
  if failed port 443 protocol https
    request "/healthz" with timeout 10 seconds
    for 2 cycles then alert
