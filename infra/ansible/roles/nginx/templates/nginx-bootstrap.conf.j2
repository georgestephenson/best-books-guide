# Managed by Ansible (roles/nginx) — temporary, replaced once a cert is issued.
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain_name }} www.{{ domain_name }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        default_type text/plain;
        return 200 "bootstrapping\n";
    }
}
