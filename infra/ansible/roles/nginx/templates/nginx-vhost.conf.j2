# Managed by Ansible (roles/nginx)

# HTTP: serve ACME renewals, redirect everything else to HTTPS.
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain_name }} www.{{ domain_name }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://{{ domain_name }}$request_uri;
    }
}

# HTTPS: redirect www to the apex.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.{{ domain_name }};

    ssl_certificate /etc/letsencrypt/live/{{ domain_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain_name }}/privkey.pem;

    return 301 https://{{ domain_name }}$request_uri;
}

# HTTPS: the app.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain_name }};

    ssl_certificate /etc/letsencrypt/live/{{ domain_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain_name }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:SSL:10m;

    root {{ app_dir }}/current/apps/web/dist;
    index index.html;

    # Security headers for the SPA document (docs/05). Nginx owns the document's
    # headers; the API sets its own via helmet. NOTE: add_header does NOT inherit
    # into a location that declares its own — so any location below that needs
    # add_header must not shadow these (see /covers/).
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-Frame-Options "DENY" always;
    add_header Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'self'" always;
    add_header Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()" always;

    location /api/ {
        proxy_pass http://127.0.0.1:{{ app_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        # Overwrite, don't append: the app trusts only the loopback hop (trustProxy),
        # so a single authoritative client IP avoids any client-supplied XFF prefix.
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /healthz {
        proxy_pass http://127.0.0.1:{{ app_port }};
        proxy_set_header Host $host;
        access_log off;
    }

    # Book covers from local disk (docs/02). `expires 30d` sets Cache-Control on
    # its own; we deliberately don't add_header here, so this block keeps inheriting
    # the security headers above (an explicit add_header would drop all of them).
    location /covers/ {
        alias {{ app_dir }}/media/;
        expires 30d;
    }

    # SPA fallback.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
