{
  "name": "best-books-guide",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Best Books Guide — a curated, opinionated best-books-by-subject site.",
  "license": "MIT",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w @bestbooks/api",
    "dev:web": "npm run dev -w @bestbooks/web",
    "build": "npm run build -w @bestbooks/shared && npm run build -w @bestbooks/api && npm run build -w @bestbooks/web",
    "typecheck": "tsc -b && tsc -p apps/web --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --project shared --project api --project web",
    "test:watch": "vitest",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.12.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "husky": "^9.1.6",
    "prettier": "^3.3.3",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
